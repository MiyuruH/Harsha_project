{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/health$",
      "dest": "api/index.py"
    },
    {
      "src": "^/qa$",
      "dest": "api/index.py"
    },
    {
      "src": "^/docs$",
      "dest": "api/index.py"
    },
    {
      "src": "^/openapi.json$",
      "dest": "api/index.py"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(?!/api|/qa|/health|/docs|/openapi.json).*$",
      "dest": "/index.html"
    }
  ]
}
